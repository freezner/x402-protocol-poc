# === x402 PoC 환경변수 ===

# Agent 지갑 개인키 (Base Sepolia 테스트넷)
# 절대 메인넷 키를 사용하지 마세요!
AGENT_PRIVATE_KEY=0x_your_agent_private_key_here

# Server 수신 지갑 주소
SERVER_WALLET_ADDRESS=0x_your_server_wallet_address_here

# Base Sepolia RPC URL
# Alchemy: https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# 공개 RPC: https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# x402 Facilitator URL (Base Sepolia 무료 커뮤니티 Facilitator)
FACILITATOR_URL=https://x402.org/facilitator

# API 서버 포트
SERVER_PORT=3000
